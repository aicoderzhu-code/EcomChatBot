# ============================================
# 生产环境配置模板
# 请复制到 /opt/ecom-chat-bot/shared/.env.production
# 并修改敏感信息
# ============================================

# ============ 基础配置 ============
ENVIRONMENT=production
DEBUG=false
APP_NAME=电商智能客服系统
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# ============ 安全配置 ============
# JWT密钥 - 请使用以下命令生成随机密钥:
# openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# API Key配置
API_KEY_PREFIX=eck_
API_KEY_LENGTH=32

# ============ LLM配置 ============
LLM_PROVIDER=deepseek

# DeepSeek配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI配置（备用）
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_API_BASE=https://api.openai.com/v1

# 智谱AI配置（备用）
ZHIPUAI_API_KEY=your_zhipuai_api_key
ZHIPUAI_MODEL=glm-4-flash

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ CORS配置 ============
# 生产环境请设置为实际的前端域名
CORS_ORIGINS=["http://localhost:3000","https://www.ecomchat.cn"]

# ============ 文件上传配置 ============
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".txt",".pdf",".doc",".docx"]

# ============ 限流配置 ============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============ 监控配置 ============
ENABLE_METRICS=true
ENABLE_TRACING=false

# ============ 通知配置（可选）============
# 企业微信Webhook
WECOM_WEBHOOK_URL=

# 钉钉Webhook
DINGTALK_WEBHOOK_URL=

# 邮件配置
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============ 备份配置 ============
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# ============ 支付回调 URL ============
ALIPAY_RETURN_URL=https://www.ecomchat.cn/payment/alipay/return
ALIPAY_NOTIFY_URL=https://www.ecomchat.cn/api/v1/payment/callback/alipay/notify
YUNGOUOS_NOTIFY_URL=https://www.ecomchat.cn/api/v1/payment/callback/yungouos/notify
