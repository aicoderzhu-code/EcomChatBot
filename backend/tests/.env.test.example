# 测试环境配置文件
# 将此文件复制为 .env.test 并填写真实的配置值

# ============ 基础配置 ============
BASE_URL=http://115.190.75.88:8000
API_PREFIX=/api/v1

# ============ 超时设置 ============
REQUEST_TIMEOUT=60
LLM_REQUEST_TIMEOUT=120

# ============ 管理员账号 ============
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============ LLM 配置 ============
# 选择 LLM 提供商: zhipuai, openai, deepseek, anthropic
LLM_PROVIDER=deepseek

# DeepSeek 配置（推荐）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 智谱AI 配置（如果使用智谱AI）
# ZHIPUAI_API_KEY=你的智谱AI_API_KEY
# ZHIPUAI_MODEL=glm-4-flash

# OpenAI 配置（如果使用OpenAI）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============ Milvus 配置 ============
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ============ 数据库配置 ============
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ecom_chatbot_test
REDIS_URL=redis://localhost:6379/0

# ============ 测试控制 ============
CLEANUP_AFTER_TEST=true
SKIP_PERFORMANCE=false
SKIP_SECURITY=false

# ============ 日志配置 ============
LOG_LEVEL=INFO
