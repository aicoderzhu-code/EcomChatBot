# Application
APP_NAME=电商智能客服系统
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ecom_chatbot
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# API Key
API_KEY_PREFIX=eck_
API_KEY_LENGTH=32

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Anthropic (Optional)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# MinIO/S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ecom-chatbot
MINIO_SECURE=false

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Monitoring
PROMETHEUS_PORT=9090
SENTRY_DSN=

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

# Webhook
WEBHOOK_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ 支付配置 ============

# 支付宝配置
ALIPAY_APPID=2021001234567890
ALIPAY_PRIVATE_KEY_PATH=/app/keys/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/keys/alipay_platform_public_key.pem
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_RETURN_URL=https://yourdomain.com/payment/alipay/return
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/v1/payment/callback/alipay/notify

# 支付宝沙箱环境（开发测试）
ALIPAY_SANDBOX=true
ALIPAY_SANDBOX_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ============ 邮件服务配置 ============

# 阿里云邮件推送（推荐国内使用）
EMAIL_PROVIDER=aliyun
ALIYUN_EMAIL_ACCESS_KEY=your-access-key
ALIYUN_EMAIL_SECRET_KEY=your-secret-key
ALIYUN_EMAIL_FROM=noreply@yourdomain.com
ALIYUN_EMAIL_FROM_NAME=电商智能客服系统

# SendGrid（国际备选）
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=EcomChatBot

# Celery Beat 定时任务
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=false
