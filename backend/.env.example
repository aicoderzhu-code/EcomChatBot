# ============ 基础配置 ============
APP_NAME=电商智能客服系统
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ============ 数据库配置 (Docker内部) ============
DATABASE_URL=postgresql+asyncpg://ecom_user:ecom_password@postgres:5432/ecom_chatbot
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis (Docker内部)
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ============ JWT密钥 (请修改为强密码) ============
JWT_SECRET=change-this-to-a-strong-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ API Key ============
API_KEY_PREFIX=eck_
API_KEY_LENGTH=32

# ============ OpenAI 配置 (使用DeepSeek API) ============
OPENAI_API_KEY=your-deepseek-api-key-here
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============ Anthropic (可选) ============
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# ============ Milvus 向量数据库 (Docker内部) ============
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# ============ Embedding 配置 ============
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ============ MinIO (Docker内部) ============
MINIO_ENDPOINT=milvus-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ecom-chatbot
MINIO_SECURE=false

# ============ RabbitMQ (Docker内部) ============
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============ 限流配置 ============
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============ 监控 (可选) ============
PROMETHEUS_PORT=9090
SENTRY_DSN=

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ 支付配置 (可选，如果不使用支付功能可以留空) ============
# 支付宝配置
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY_PATH=/app/keys/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/keys/alipay_platform_public_key.pem
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_RETURN_URL=https://www.ecomchat.cn/payment/alipay/return
ALIPAY_NOTIFY_URL=https://www.ecomchat.cn/api/v1/payment/callback/alipay/notify

# 支付宝沙箱环境（开发测试）
ALIPAY_SANDBOX=true
ALIPAY_SANDBOX_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ============ 邮件服务 (可选) ============
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ============ Celery定时任务 ============
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=false
